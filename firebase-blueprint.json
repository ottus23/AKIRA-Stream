{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "super_admin"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Anime": {
      "title": "Anime",
      "description": "Anime series or movie",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["series", "movie"] },
        "status": { "type": "string", "enum": ["ongoing", "completed", "draft"] },
        "genres": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "status", "genres"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/anime/{animeId}": {
      "schema": { "$ref": "Anime" },
      "description": "Anime content"
    },
    "/movies/{movieId}": {
      "schema": { "$ref": "Anime" },
      "description": "Movies"
    },
    "/seasons/{seasonId}": {
      "schema": {
        "type": "object",
        "properties": {
          "animeId": { "type": "string" },
          "seasonNumber": { "type": "number" },
          "title": { "type": "string" }
        },
        "required": ["animeId", "seasonNumber"]
      },
      "description": "Seasons of series"
    },
    "/episodes/{episodeId}": {
      "schema": {
        "type": "object",
        "properties": {
          "seasonId": { "type": "string" },
          "episodeNumber": { "type": "number" },
          "title": { "type": "string" }
        },
        "required": ["seasonId", "episodeNumber"]
      },
      "description": "Episodes of seasons"
    },
    "/sources/{sourceId}": {
      "schema": { "type": "object" },
      "description": "Video sources"
    },
    "/subtitles/{subtitleId}": {
      "schema": { "type": "object" },
      "description": "Subtitle files"
    }
  }
}
