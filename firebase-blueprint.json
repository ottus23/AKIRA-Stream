{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "super_admin"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Franchise": {
      "title": "Franchise",
      "description": "Grouping of related titles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Title": {
      "title": "Title",
      "description": "Anime title entity (series, movie, etc.)",
      "type": "object",
      "properties": {
        "franchiseId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["series", "movie", "ova", "special", "trailer", "clip"] },
        "status": { "type": "string", "enum": ["ongoing", "completed", "draft"] },
        "genres": { "type": "array", "items": { "type": "string" } },
        "synopsis": { "type": "string" },
        "poster_url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "status", "genres"]
    },
    "Source": {
      "title": "Source",
      "description": "Official YouTube source content",
      "type": "object",
      "properties": {
        "source_name": { "type": "string" },
        "source_type": { "type": "string" },
        "source_url": { "type": "string" },
        "youtube_channel_id": { "type": "string" },
        "youtube_playlist_id": { "type": "string" },
        "youtube_video_id": { "type": "string" },
        "dub_language": { "type": "string" },
        "caption_language": { "type": "string" },
        "license_status": { "type": "string" },
        "last_synced_at": { "type": "string", "format": "date-time" }
      },
      "required": ["source_name", "source_type", "source_url"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/franchises/{franchiseId}": {
      "schema": { "$ref": "Franchise" },
      "description": "Anime franchises"
    },
    "/titles/{titleId}": {
      "schema": { "$ref": "Title" },
      "description": "Anime titles"
    },
    "/sources/{sourceId}": {
      "schema": { "$ref": "Source" },
      "description": "Content sources"
    }
  }
}
